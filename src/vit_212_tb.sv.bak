`timescale 1ns/1ps

module vit_212_tb;

    localparam DEPTH = 8;
    localparam PM_WIDTH = 4;

    reg clk;
    reg rst_n;

    reg        i_valid;
    reg [1:0]  i_data;
    reg        i_last;

    wire       o_valid;
    wire       o_data;
    wire       o_last;

    // Instantiate DUT
    vit_212_top #(
        .DEPTH(DEPTH),
        .PM_WIDTH(PM_WIDTH)
    ) dut (
        .clk(clk),
        .rst_n(rst_n),
        .i_valid(i_valid),
        .i_data(i_data),
        .i_last(i_last),
        .o_valid(o_valid),
        .o_data(o_data),
        .o_last(o_last)
    );

    //--------------------------------------------------------
    // Clock 100MHz
    //--------------------------------------------------------
    initial clk = 0;
    always #5 clk = ~clk;

    //--------------------------------------------------------
    // Test sequence
    //--------------------------------------------------------

    reg [1:0] rx_vec [0:DEPTH-1];

    integer i;

    initial begin

        // Ví d? hard decision input (tůy b?n thay)
        rx_vec[0] = 2'b10;
        rx_vec[1] = 2'b11;
        rx_vec[2] = 2'b00;
        rx_vec[3] = 2'b01;
        rx_vec[4] = 2'b10;
        rx_vec[5] = 2'b11;
        rx_vec[6] = 2'b00;
        rx_vec[7] = 2'b01;

        //----------------------------------------------------
        // Reset
        //----------------------------------------------------
        rst_n   = 0;
        i_valid = 0;
        i_data  = 0;
        i_last  = 0;

        #30;
        rst_n = 1;

        #20;

        //----------------------------------------------------
        // Send 1 frame
        //----------------------------------------------------
        for (i = 0; i < DEPTH; i = i + 1) begin
            @(posedge clk);
            i_valid <= 1;
            i_data  <= rx_vec[i];

            if (i == DEPTH-1)
                i_last <= 1;
            else
                i_last <= 0;
        end

        //----------------------------------------------------
        // Stop input
        //----------------------------------------------------
        @(posedge clk);
        i_valid <= 0;
        i_last  <= 0;

        //----------------------------------------------------
        // Wait until output finishes
        //----------------------------------------------------
        wait(o_last);

        #50;
        $finish;
    end

    //--------------------------------------------------------
    // Monitor output
    //--------------------------------------------------------

    always @(posedge clk) begin
        if (o_valid)
            $display("Time=%0t  Decoded bit=%0d", $time, o_data);

        if (o_last)
            $display("---- Frame Done ----");
    end

endmodule