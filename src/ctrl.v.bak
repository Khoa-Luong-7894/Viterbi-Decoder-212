module ctrl #(
    parameter DEPTH = 8
)(
    input  wire clk,
    input  wire rst_n,
    input  wire i_valid,
    input  wire i_last,

    output reg  pm_we,
    output reg  smu_we,
    output reg  tb_en,
    output reg  bank_sel,
    output reg  load_state,
    output reg  [2:0] fw_idx,
    output reg  [2:0] tb_idx,
    output reg  o_valid,
    output reg  o_last
);

    localparam S_IDLE   = 2'd0;
    localparam S_RUN    = 2'd1;
    localparam S_FLUSH  = 2'd2;

    reg [1:0] state;
    reg first_frame_done;
    reg last_seen;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            state <= S_IDLE;
            fw_idx <= 0;
            tb_idx <= 0;
            bank_sel <= 0;
            pm_we <= 0;
            smu_we <= 0;
            tb_en <= 0;
            load_state <= 0;
            o_valid <= 0;
            o_last <= 0;
            first_frame_done <= 0;
            last_seen <= 0;
        end
        else begin

            // default outputs
            pm_we <= 0;
            smu_we <= 0;
            tb_en <= 0;
            load_state <= 0;
            o_valid <= 0;
            o_last <= 0;

            //----------------------------------
            // FORWARD (must align with i_valid)
            //----------------------------------
            if (i_valid && state != S_FLUSH) begin
                pm_we  <= 1;
                smu_we <= 1;

                if (fw_idx == DEPTH-1) begin
                    fw_idx <= 0;
                    tb_idx <= DEPTH-1;
                    bank_sel <= ~bank_sel;
                    load_state <= 1;
                    first_frame_done <= 1;
                end
                else begin
                    fw_idx <= fw_idx + 1;
                end

                if (i_last)
                    last_seen <= 1;
            end

            //----------------------------------
            // STATE MACHINE
            //----------------------------------
            case (state)

                S_IDLE:
                    if (i_valid)
                        state <= S_RUN;

                S_RUN: begin
                    // Traceback ch? khi ?Ð cµ frame ??u
                    if (first_frame_done) begin
                        tb_en   <= 1;
                        o_valid <= 1;

                        if (tb_idx == 0)
                            tb_idx <= DEPTH-1;
                        else
                            tb_idx <= tb_idx - 1;
                    end

                    if (last_seen && !i_valid)
                        state <= S_FLUSH;
                end

                S_FLUSH: begin
                    tb_en   <= 1;
                    o_valid <= 1;

                    if (tb_idx == 0) begin
                        o_last <= 1;
                        state <= S_IDLE;
                        first_frame_done <= 0;
                        last_seen <= 0;
                    end
                    else
                        tb_idx <= tb_idx - 1;
                end
            endcase
        end
    end
endmodule